rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/user_roles/$(request.auth.uid + "_admin"));
    }

    // Profiles
    match /profiles/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    // User Roles
    match /user_roles/{roleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // User Credits
    match /user_credits/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.balance == 0;
      allow update, delete: if isAdmin();
    }

    // Tournaments
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Tournament Participants
    match /tournament_participants/{participantId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Mini Tournaments
    match /mini_tournaments/{tournamentId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin() || 
                      isOwner(resource.data.organizer_id) ||
                      (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['current_participants']));
      allow delete: if isAdmin();
    }

    match /mini_tournament_participants/{participantId} {
      allow read: if true;
      allow create, delete: if isAuthenticated();
    }

    match /mini_tournament_messages/{messageId} {
      allow read: if true;
      allow create: if isAuthenticated();
    }

    // Communities
    match /communities/{communityId} {
      allow read: if true;
      allow write: if isAuthenticated(); // Broadly open for now, could be tightened to owner
    }

    match /community_members/{memberId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /channels/{channelId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /messages/{messageId} {
      allow read: if true;
      allow create: if isAuthenticated();
    }

    // LFG Ads
    match /lfg_ads/{adId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if isAuthenticated();
    }

    // Matches / Duels
    match /matches/{matchId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAdmin() || 
                      isOwner(resource.data.creator_id) || 
                      (isAuthenticated() && resource.data.status == 'open'); // Allows accepting a duel
      allow delete: if isAdmin();
    }

    // Followers
    match /followers/{followerId} {
      allow read: if true;
      allow create, delete: if isAuthenticated();
    }

    // Site Stats (Visitor Tracking)
    match /site_stats/{date} {
      allow read: if true;
      allow write: if true; // Allows VisitorTracker to work for guests and users
    }

    // Recent Activities
    match /recent_activities/{activityId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // PIX Keys
    match /user_pix_keys/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /organizer_payment_info/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Default allow read for unknown collections to prevent crashes, write restricted
    match /{collection}/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
